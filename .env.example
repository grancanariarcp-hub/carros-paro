# Copia este archivo a .env.local y rellena los valores
# Ambiente: dev → astor-dev | prod → agpawdoibqdptgdkcktv

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=b_publishable_or_eyJ...

# Solo backend / edge functions / scripts admin — nunca exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (observabilidad)
# DSN público — copia desde sentry.io → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
# Auth token para subir sourcemaps en build (solo Vercel/CI)
# Generar en sentry.io → Settings → Auth Tokens con scope project:write
SENTRY_AUTH_TOKEN=

# Web Push — clave pública VAPID (la misma que en private.app_secrets.vapid_public_key)
# Es pública por diseño: el navegador la usa para identificar al servidor de push.
# La privada NO se pone aquí ni se expone al cliente, vive solo en BD.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
